# Auto detect text files and normalize line endings to LF
* text=auto

# Java files
*.java text eol=lf
*.class binary
*.jar binary
*.war binary

# Maven
pom.xml text eol=lf
mvnw text eol=lf
mvnw.cmd text eol=crlf
*.mvn text eol=lf

# Configuration files
*.properties text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.xml text eol=lf
*.json text eol=lf
*.gradle text eol=lf

# Documentation
*.md text eol=lf
*.txt text eol=lf
*.md diff=markdown

# Git
.gitattributes text eol=lf
.gitignore text eol=lf

# IDE
.idea/** text eol=lf
.vscode/** text eol=lf
*.iml binary

# Build
target/** binary
build/** binary
.gradle/** binary

# OS
.DS_Store binary
Thumbs.db binary

# Docker
Dockerfile text eol=lf
docker-compose.yml text eol=lf
.dockerignore text eol=lf
